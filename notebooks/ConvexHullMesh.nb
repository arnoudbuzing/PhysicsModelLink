Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Create", " ", "world", " ", "with", " ", "one", " ", "moving", " ", 
    "ball", " ", "and", " ", "a", " ", "fixed", " ", "floor"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"model", "=", 
     RowBox[{"CreatePhysicsModel", "[", 
      RowBox[{
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"DynamicBody", "[", 
          RowBox[{
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0", ",", "2"}], "}"}], ",", "0.2"}], "]"}], ",", 
           RowBox[{"\"\<Density\>\"", "->", "1.0"}], ",", 
           RowBox[{"\"\<Restitution\>\"", "->", "0.8"}], ",", 
           RowBox[{"\"\<Friction\>\"", "->", "0.2"}], ",", 
           RowBox[{"\"\<Velocity\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"1.5", ",", "0.0", ",", "2.0"}], "}"}]}]}], "   ", 
          RowBox[{"(*", 
           RowBox[{"initial", " ", "linear", " ", "velocity"}], "*)"}], "]"}],
          ",", 
         RowBox[{"FixedBody", "[", 
          RowBox[{
           RowBox[{"Cuboid", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "2"}], ",", 
               RowBox[{"-", "2"}], ",", 
               RowBox[{"-", "0.2"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"2", ",", "2", ",", "0"}], "}"}]}], "]"}], ",", 
           RowBox[{"\"\<Restitution\>\"", "->", "0.6"}], ",", 
           RowBox[{"\"\<Friction\>\"", "->", "0.8"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"\"\<Gravity\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", 
          RowBox[{"-", "9.81"}]}], "}"}]}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Simulate", "~", "3"}], " ", "seconds"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"frames", "=", 
     RowBox[{"PhysicsModelEvolve", "[", 
      RowBox[{"model", ",", "180", ",", 
       RowBox[{"1", "/", "60.0"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Quick", " ", "visualization"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"PhysicsModelAnimate", "[", "frames", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9851881923784943`*^9, 3.985188192378537*^9}, {
  3.985188242339879*^9, 3.9851882713036118`*^9}, {3.9851887154676723`*^9, 
  3.9851887208526287`*^9}},
