          ArnoudBuzing`PhysicsModelLink`Private`gravity, 
          ArnoudBuzing`PhysicsModelLink`Private`worldId, 
          ArnoudBuzing`PhysicsModelLink`Private`bodyData, 
          ArnoudBuzing`PhysicsModelLink`Private`g3dOpts}, 
         ArnoudBuzing`PhysicsModelLink`Private`flatBodies = 
          Flatten[ArnoudBuzing`PhysicsModelLink`Private`bodies]; 
         ArnoudBuzing`PhysicsModelLink`Private`gravity = N[
            OptionValue["Gravity"]]; 
         ArnoudBuzing`PhysicsModelLink`Private`g3dOpts = 
          OptionValue["Graphics3DOptions"]; 
         ArnoudBuzing`PhysicsModelLink`Private`worldId = 
          ArnoudBuzing`PhysicsModelLink`RapierWorldCreate[
           ArnoudBuzing`PhysicsModelLink`Private`gravity]; 
         ArnoudBuzing`PhysicsModelLink`Private`bodyData = Table[
            ArnoudBuzing`PhysicsModelLink`Private`createBody[
            ArnoudBuzing`PhysicsModelLink`Private`worldId, 
             ArnoudBuzing`PhysicsModelLink`Private`body], {
            ArnoudBuzing`PhysicsModelLink`Private`body, 
             ArnoudBuzing`PhysicsModelLink`Private`flatBodies}]; 
         ArnoudBuzing`PhysicsModelLink`Private`bodyData = 
          Select[ArnoudBuzing`PhysicsModelLink`Private`bodyData, 
            AssociationQ]; If[
           And[
            FreeQ[ArnoudBuzing`PhysicsModelLink`Private`g3dOpts, PlotRange], 
            Length[ArnoudBuzing`PhysicsModelLink`Private`bodyData] > 0], 
           ArnoudBuzing`PhysicsModelLink`Private`g3dOpts = 
           Append[ArnoudBuzing`PhysicsModelLink`Private`g3dOpts, PlotRange -> 
             ArnoudBuzing`PhysicsModelLink`Private`computePlotRange[
              ArnoudBuzing`PhysicsModelLink`Private`bodyData]]]; 
         Module[{ArnoudBuzing`PhysicsModelLink`Private`model, 
            ArnoudBuzing`PhysicsModelLink`Private`icon}, 
           ArnoudBuzing`PhysicsModelLink`Private`model = 
            ArnoudBuzing`PhysicsModelLink`PhysicsModelObject[<|
              "WorldID" -> ArnoudBuzing`PhysicsModelLink`Private`worldId, 
               "Bodies" -> ArnoudBuzing`PhysicsModelLink`Private`bodyData, 
               "Time" -> 0., "Graphics3DOptions" -> 
               ArnoudBuzing`PhysicsModelLink`Private`g3dOpts, "Icon" -> 
               None|>]; ArnoudBuzing`PhysicsModelLink`Private`icon = Quiet[
              Rasterize[
               ArnoudBuzing`PhysicsModelLink`PhysicsModelPlot[
               ArnoudBuzing`PhysicsModelLink`Private`model, Axes -> False, 
                Boxed -> False], "Image", ImageSize -> 80]]; 
           ArnoudBuzing`PhysicsModelLink`PhysicsModelObject[
             Append[
              Part[ArnoudBuzing`PhysicsModelLink`Private`model, 1], "Icon" -> 
              ArnoudBuzing`PhysicsModelLink`Private`icon]]]]}], "SubValues" -> 
    None, "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {"Gravity" -> {0, 0, -9.81}, "Graphics3DOptions" -> {}}, 
    "Attributes" -> {}, "FullName" -> 
    "ArnoudBuzing`PhysicsModelLink`CreatePhysicsModel"|>, False]]], "Output",
 CellChangeTimes->{3.985965285897674*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"b1a23010-097a-4d33-94e2-adc2b034f5ec"]
