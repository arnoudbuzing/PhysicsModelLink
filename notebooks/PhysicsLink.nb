0ec884aba100"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Create", " ", "a", " ", "scene", " ", "with", " ", "a", " ", "floor"}], ",", 
    RowBox[{"a", " ", "bouncing", " ", "sphere"}], ",", 
    RowBox[{"a", " ", "tumbling", " ", "cuboid"}], ",", 
    RowBox[{"and", " ", "a", " ", "cylinder"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"model", "=", 
   RowBox[{"CreatePhysicsModel", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Floor", ":", 
        RowBox[{
        "a", " ", "large", " ", "thin", " ", "fixed", " ", "cuboid"}]}], 
       "*)"}], 
      RowBox[{
       RowBox[{"FixedBody", "[", 
        RowBox[{"Cuboid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "8"}], ",", 
            RowBox[{"-", "8"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"8", ",", "8", ",", "0"}], "}"}]}], "]"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "A", " ", "sphere", " ", "dropped", " ", "from", " ", "height", " ", 
         "5"}], "*)"}], 
       RowBox[{"DynamicBody", "[", 
        RowBox[{
         RowBox[{"Sphere", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "5"}], "}"}], ",", "0.5"}], "]"}], ",", 
         RowBox[{"\"\<Density\>\"", "->", "2.0"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "A", " ", "cuboid", " ", "with", " ", "a", " ", "tilted", " ", 
         "initial", " ", "orientation"}], "*)"}], 
       RowBox[{"DynamicBody", "[", 
        RowBox[{
         RowBox[{"Cuboid", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "0.5"}], ",", "0.0", ",", "7.5"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0.5", ",", "0.5", ",", "8.5"}], "}"}]}], "]"}], ",", 
         RowBox[{"\"\<Orientation\>\"", "->", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{
            RowBox[{"Pi", "/", "4"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "A", " ", "cylinder", " ", "off", " ", "to", " ", "the", " ", 
         "side"}], "*)"}], 
       RowBox[{"DynamicBody", "[", 
        RowBox[{"Cylinder", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"2", ",", "0", ",", "5.4"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"2", ",", "0", ",", "6.6"}], "}"}]}], "}"}], ",", 
          "0.35"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"A", " ", "fixed", " ", "sphere", " ", "obstacle"}], "*)"}], 
       RowBox[{"FixedBody", "[", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "2"}], ",", "0", ",", "0.8"}], "}"}], ",", "0.8"}], 
         "]"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<Gravity\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", 
        RowBox[{"-", "9.81"}]}], "}"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.984824753891632*^9, 3.984824783867713*^9}, {
