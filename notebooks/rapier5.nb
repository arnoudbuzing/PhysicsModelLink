            RowBox[{"qx", "^", "2"}], "+", 
            RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"qy", " ", "qz"}], "-", 
           RowBox[{"qw", " ", "qx"}]}], ")"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"qx", " ", "qz"}], "-", 
           RowBox[{"qw", " ", "qy"}]}], ")"}]}], ",", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"qy", " ", "qz"}], "+", 
