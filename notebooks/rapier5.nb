Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"quatToMatrix", "[", 
      RowBox[{"{", 
       RowBox[{"qx_", ",", "qy_", ",", "qz_", ",", "qw_"}], "}"}], "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qy", "^", "2"}], "+", 
             RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qy"}], "-", 
            RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qz"}], "+", 
            RowBox[{"qw", " ", "qy"}]}], ")"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qy"}], "+", 
            RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
         RowBox[{"1", "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", "^", "2"}], "+", 
             RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qy", " ", "qz"}], "-", 
            RowBox[{"qw", " ", "qx"}]}], ")"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", " ", "qz"}], "-", 
            RowBox[{"qw", " ", "qy"}]}], ")"}]}], ",", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qy", " ", "qz"}], "+", 
            RowBox[{"qw", " ", "qx"}]}], ")"}]}], ",", 
         RowBox[{"1", "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"qx", "^", "2"}], "+", 
             RowBox[{"qy", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "}"}]}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rowToTransform", "[", "row_", "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"quatToMatrix", "[", 
        RowBox[{"row", "[", 
         RowBox[{"[", 
          RowBox[{"5", ";;", "8"}], "]"}], "]"}], "]"}], ",", 
       RowBox[{"row", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;", "4"}], "]"}], "]"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"handleToTransform", "[", "mat_", "]"}], ":=", 
     RowBox[{"Association", "@", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "->", 
           RowBox[{"rowToTransform", "[", "#", "]"}]}], ")"}], "&"}], ",", 
        "mat"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "worldId", ",", "floorId", ",", "capsuleBodyId", ",", "dt", ",", 
       "steps", ",", "frames"}], "}"}], ",", 
     RowBox[{
      RowBox[{"worldId", "=", 
       RowBox[{"RapierWorldCreate", "[", 
        RowBox[{"{", 
         RowBox[{"0.0", ",", "0.0", ",", 
          RowBox[{"-", "9.81"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"floorId", "=", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0.0", ",", "0.0", ",", 
           RowBox[{"-", "1.0"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"RapierAddColliderCuboid", "[", 
       RowBox[{"worldId", ",", "floorId", ",", 
        RowBox[{"{", 
         RowBox[{"8.0", ",", "8.0", ",", "1.0"}], "}"}], ",", "1.0"}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"capsuleBodyId", "=", 
       RowBox[{"RapierAddRigidBody", "[", 
        RowBox[{"worldId", ",", 
         RowBox[{"{", 
          RowBox[{"0.0", ",", "0.0", ",", "5.0"}], "}"}], 
         ",", "\"\<Dynamic\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"RapierAddColliderCapsule", "[", 
       RowBox[{"worldId", ",", "capsuleBodyId", ",", 
        RowBox[{"{", 
         RowBox[{"0.6", ",", "0.25"}], "}"}], ",", "1.0"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dt", "=", 
       RowBox[{"1.0", "/", "60.0"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"steps", "=", "240"}], ";", "\[IndentingNewLine]", 
      RowBox[{"frames", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"RapierWorldStep", "[", 
           RowBox[{"worldId", ",", "1", ",", "dt"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"RapierGetBodyPositions", "[", "worldId", "]"}]}], ",", 
         RowBox[{"{", "steps", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ListAnimate", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", "=", 
              RowBox[{"handleToTransform", "[", "frame", "]"}]}], "}"}], ",", 
            
            RowBox[{"Graphics3D", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"Gray", ",", 
                RowBox[{"GeometricTransformation", "[", 
                 RowBox[{
                  RowBox[{"Cuboid", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "8"}], ",", 
                    RowBox[{"-", "8"}], ",", 
                    RowBox[{"-", "1"}]}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"8", ",", "8", ",", "1"}], "}"}]}], "]"}], ",", 
                  RowBox[{"t", "[", "floorId", "]"}]}], "]"}], ",", 
                RowBox[{"Darker", "@", "Green"}], ",", 
                RowBox[{"GeometricTransformation", "[", 
                 RowBox[{
                  RowBox[{"CapsuleShape", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0", ",", 
                    RowBox[{"-", "0.6"}]}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0", ",", "0.6"}], "}"}]}], "}"}], ",", 
                    "0.25"}], "]"}], ",", 
                  RowBox[{"t", "[", "capsuleBodyId", "]"}]}], "]"}]}], "}"}], 
              ",", 
              RowBox[{"PlotRange", "->", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "6"}], ",", "6"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "6"}], ",", "6"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "2"}], ",", "8"}], "}"}]}], "}"}]}], ",", 
              RowBox[{"Axes", "->", "True"}], ",", 
              RowBox[{"Boxed", "->", "True"}]}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"frame", ",", "frames"}], "}"}]}], "]"}], ",", 
        RowBox[{"AnimationRate", "->", "60"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"RapierWorldDestroy", "[", "worldId", "]"}]}]}], "]"}], 
   "\n"}]}]], "Input",
