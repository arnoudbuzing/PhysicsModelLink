 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"quatToMatrix", "[", 
     RowBox[{"{", 
      RowBox[{"qx_", ",", "qy_", ",", "qz_", ",", "qw_"}], "}"}], "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "-", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qy", "^", "2"}], "+", 
            RowBox[{"qz", "^", "2"}]}], ")"}]}]}], ",", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"qx", " ", "qy"}], "-", 
           RowBox[{"qw", " ", "qz"}]}], ")"}]}], ",", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"qx", " ", "qz"}], "+", 
           RowBox[{"qw", " ", "qy"}]}], ")"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"2", " ", 
