        RowBox[{"1", "-", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"qx", "^", "2"}], "+", 
            RowBox[{"qy", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "}"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rowToTransform", "[", "row_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"quatToMatrix", "[", 
      RowBox[{"row", "[", 
       RowBox[{"[", 
        RowBox[{"5", ";;", "8"}], "]"}], "]"}], "]"}], ",", 
     RowBox[{"row", "[", 
      RowBox[{"[", 
       RowBox[{"2", ";;", "4"}], "]"}], "]"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"handleToTransform", "[", "mat_", "]"}], ":=", 
    RowBox[{"Association", "@", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "->", 
          RowBox[{"rowToTransform", "[", "#", "]"}]}], ")"}], "&"}], ",", 
       "mat"}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "worldId", ",", "floorId", ",", "capsuleBodyId", ",", "dt", ",", "steps", 
     ",", "frames"}], "}"}], ",", 
   RowBox[{
    RowBox[{"worldId", "=", 
     RowBox[{"RapierWorldCreate", "[", 
      RowBox[{"{", 
       RowBox[{"0.0", ",", "0.0", ",", 
        RowBox[{"-", "9.81"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"floorId", "=", 
     RowBox[{"RapierAddRigidBody", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.0", ",", 
         RowBox[{"-", "1.0"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"RapierAddColliderCuboid", "[", 
     RowBox[{"worldId", ",", "floorId", ",", 
      RowBox[{"{", 
       RowBox[{"8.0", ",", "8.0", ",", "1.0"}], "}"}], ",", "1.0"}], "]"}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"capsuleBodyId", "=", 
     RowBox[{"RapierAddRigidBody", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.0", ",", "5.0"}], "}"}], 
       ",", "\"\<Dynamic\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"RapierAddColliderCapsule", "[", 
     RowBox[{"worldId", ",", "capsuleBodyId", ",", 
      RowBox[{"{", 
       RowBox[{"0.6", ",", "0.25"}], "}"}], ",", "1.0"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"dt", "=", 
     RowBox[{"1.0", "/", "60.0"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"steps", "=", "240"}], ";", "\[IndentingNewLine]", 
    RowBox[{"frames", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"RapierWorldStep", "[", 
         RowBox[{"worldId", ",", "1", ",", "dt"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"RapierGetBodyPositions", "[", "worldId", "]"}]}], ",", 
