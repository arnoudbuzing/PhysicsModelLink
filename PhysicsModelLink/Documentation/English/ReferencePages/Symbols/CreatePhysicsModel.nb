Cell["CreatePhysicsModel", "ObjectName",
 CellID->323186295,ExpressionUUID->"5ed210e5-d0af-4d9d-ac38-d5d15089d5f9"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"83e5207d-dc01-4565-aff0-c30ff7d6a181"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["CreatePhysicsModel",
    BaseStyle->"Link",
    ButtonData->"paclet:ArnoudBuzingPhysicsModelLink/ref/CreatePhysicsModel"],
    "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["body", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["body", "TI"], 
       StyleBox["2", "TR"]], ",", " ", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "feee645c-4096-448e-8a87-3fb3286b7329"],
 "\[LineSeparator]creates a physics simulation from DynamicBody/FixedBody \
wrapped primitives. Returns a ",
 Cell[BoxData[
  ButtonBox["PhysicsModelObject",
   BaseStyle->"Link",
   ButtonData->
    "paclet:ArnoudBuzing/PhysicsModelLink/ref/PhysicsModelObject"]], 
  "InlineFormula",ExpressionUUID->"2a15310c-6764-410e-8767-8df0e49a9ed0"],
 "."
}], "Usage",
 CellChangeTimes->{3.985009372473628*^9},
 CellID->805916802,ExpressionUUID->"87da3161-7286-4095-9911-d9c20aa5f711"],

