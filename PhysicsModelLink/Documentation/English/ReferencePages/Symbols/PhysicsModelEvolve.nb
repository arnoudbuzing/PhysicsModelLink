Cell[CellGroupData[{
Cell["PhysicsModelEvolve", "ObjectName",
 CellChangeTimes->{{3.985811311050345*^9, 3.985811311163837*^9}},
 CellID->1922703757,ExpressionUUID->"4b616637-7312-4bf7-acd8-d6c202dc48ea"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5b7d4022-8098-452a-ab79-b532b9ec45f8"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["PhysicsModelEvolve",
    BaseStyle->"Link",
    ButtonData->"paclet:ArnoudBuzingPhysicsModelLink/ref/PhysicsModelEvolve"],
    "[", 
   RowBox[{
    StyleBox["model", "TI"], ",", 
    StyleBox["frames", "TI"], ",", 
    StyleBox["dt", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "d44cba28-a39f-43bd-8fc1-ba99308323e0"],
 "\[LineSeparator]evolves the ",
 Cell[BoxData[
  StyleBox["model", "TI"]], "InlineFormula",ExpressionUUID->
  "a2a5ea61-6fd7-442f-a335-379826dd7792"],
 " for the given number of ",
 Cell[BoxData[
  StyleBox["frames", "TI"]], "InlineFormula",ExpressionUUID->
  "32c61ee4-1c09-4ea6-b1ff-ad3900c7dfc5"],
 " at time step ",
 Cell[BoxData[
  StyleBox["dt", "TI"]], "InlineFormula",ExpressionUUID->
  "cbfb2dc0-69ce-4324-bff0-73ac97ad4b57"],
 ", returning a list of ",
 Cell[BoxData[
  ButtonBox["PhysicsModelObject",
   BaseStyle->"Link",
   ButtonData->
    "paclet:ArnoudBuzing/PhysicsModelLink/ref/PhysicsModelObject"]], 
  "InlineFormula",ExpressionUUID->"d3da7401-1c16-4dae-959a-29b0bb3c15ea"],
 " states."
}], "Usage",
