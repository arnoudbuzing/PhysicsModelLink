Cell["Create a collection of \"dominoes\":", "ExampleText",
 TaggingRules->{},
 CellChangeTimes->{{3.985204660035091*^9, 3.985204686741102*^9}},
 CellID->1197853575,ExpressionUUID->"0965527d-89b4-4386-9111-9495d60e93a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dominoes", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"DynamicBody", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"MaterialShading", "[", "\"\<Copper\>\"", "]"}], ",", 
        RowBox[{"Cuboid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "-", "0.08"}], ",", 
            RowBox[{"-", "0.3"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "+", "0.08"}], ",", "0.3", ",", "0.8"}], "}"}]}], 
         "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3", ",", "0.6"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.9852046253892927`*^9}},
 CellLabel->"In[13]:=",
 CellID->1304413954,ExpressionUUID->"7c9e795a-c6d5-4ad0-84df-8e01bb787078"],

Cell["Create a ball that will push over the dominoes:", "ExampleText",
 TaggingRules->{},
 CellChangeTimes->{{3.9852046911742487`*^9, 3.985204704261531*^9}},
 CellID->923275861,ExpressionUUID->"babb4961-e8d1-49df-84f3-e0d57840add4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ball", "=", 
   RowBox[{"DynamicBody", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"MaterialShading", "[", "\"\<Gold\>\"", "]"}], ",", 
       RowBox[{"Sphere", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3.8"}], ",", "0", ",", "0.4"}], "}"}], ",", "0.35"}],
         "]"}]}], "}"}], ",", 
     RowBox[{"\"\<Density\>\"", "->", "5.0"}], ",", 
     RowBox[{"\"\<Velocity\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"3", ",", "0", ",", "0"}], "}"}]}]}], "]"}]}], ";"}]], "Input",\

 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.985204631501656*^9}, {
  3.985204721759603*^9, 3.985204722366427*^9}},
 CellLabel->"In[14]:=",
 CellID->1772256302,ExpressionUUID->"dd27d6d9-a255-482d-a201-b7c13626d608"],

Cell["Create the model from the ball and dominoes:", "ExampleText",
 TaggingRules->{},
 CellChangeTimes->{{3.9852047095903397`*^9, 3.98520471956244*^9}},
 CellID->1421090451,ExpressionUUID->"b14faf15-ab3b-433e-88e8-13320d04ad91"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "4"}], ",", 
            RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
        RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"HatchShading", "[", 
          RowBox[{".6", ",", "Gray"}], "]"}], ",", 
         RowBox[{"Cuboid", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], "]"}],
       ",", "dominoes", ",", "ball"}], "}"}], ",", 
    RowBox[{"\"\<Gravity\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{"-", "9.81"}]}], "}"}]}], ",", 
    RowBox[{"\"\<Graphics3DOptions\>\"", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Background", "->", "Black"}], ",", 
       RowBox[{"Axes", "->", "False"}], ",", 
       RowBox[{"Boxed", "->", "False"}], ",", 
       RowBox[{"ViewPoint", "->", "Front"}], ",", 
       RowBox[{"ImageSize", "->", "Large"}]}], "}"}]}]}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985204622964322*^9, 3.985204633422715*^9}, {
   3.9852047271076183`*^9, 3.9852047274741697`*^9}, 3.98581145923864*^9},
 CellLabel->"In[15]:=",
 CellID->364826354,ExpressionUUID->"06494704-3366-4338-b686-5f01d7745afe"],

