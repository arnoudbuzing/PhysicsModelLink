Cell["\<\
Create a model with a dodecahedron rolling on an inclined plane:\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.985204018415174*^9, 3.985204060034947*^9}, {
  3.985204511598761*^9, 3.9852045265205927`*^9}},
 CellTags->"DefaultContent",
 CellID->385916280,ExpressionUUID->"6acf070f-9947-4ca0-986f-5806f7967cac"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dodecahedron", "=", 
   RowBox[{"Translate", "[", 
    RowBox[{
     RowBox[{"ConvexHullMesh", "[", 
      RowBox[{"N", "[", 
       RowBox[{"PolyhedronData", "[", 
        RowBox[{"\"\<Dodecahedron\>\"", ",", "\"\<Points\>\""}], "]"}], "]"}],
       "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"DynamicBody", "[", 
       RowBox[{"{", 
        RowBox[{"StandardOrange", ",", 
         RowBox[{"HatchShading", "[", "]"}], ",", "dodecahedron"}], "}"}], 
       "]"}], ",", 
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "7"}], "}"}]}], "}"}], "]"}], ",", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{"Gray", ",", 
         RowBox[{"HatchShading", "[", "]"}], ",", 
         RowBox[{"ConvexHullMesh", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", 
              RowBox[{"-", "5"}], ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", "5", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", 
              RowBox[{"-", "5"}], ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", 
              RowBox[{"-", "5"}], ",", "1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5", ",", "1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", "5", ",", "3"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", 
              RowBox[{"-", "5"}], ",", "3"}], "}"}]}], "}"}], "]"}]}], "}"}], 
       "]"}]}], "}"}], ",", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", 
        RowBox[{
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], 
          "\[Rule]", 
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]]}], 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Rule", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["928", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     "Graphics3DOptions" -> {
      ViewPoint -> Front, PlotRange -> 1.01 {{-5, 5}, {-5, 5}, {0, 7}}, 
       Background -> Black, Axes -> False, Boxed -> False, ImageSize -> Large},
     SelectWithContents->True,
     Selectable->False]}], "]"}]}]}], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.9852044622730217`*^9, 3.9852044899992027`*^9}, {
  3.9858088038017073`*^9, 3.9858088316222277`*^9}},
 CellLabel->"In[3]:=",
