Cell[TextData[{
 "PhysicsModelLink provides rigid body physics simulation for standard \
Wolfram Language 3D graphics primitives including ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Sphere", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Sphere",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ccf947d9-37b0-43ac-a3ff-61a7b1997346"],
 ", ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Cuboid", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Cuboid",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0d3d63f7-2f0a-4421-b24d-2ed6b738dcd5"],
 ", ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Cylinder", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Cylinder",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0e090d6e-e3c0-456c-9db6-78032fac09f3"],
 ", ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Cone", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Cone",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "85c87801-d2b4-4879-91f2-f3c02d9168b0"],
 ", and ",
 Cell[BoxData[
