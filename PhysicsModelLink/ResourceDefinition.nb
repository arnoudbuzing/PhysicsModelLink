Cell["\<\
Create a model with four balls with various levels of bounciness:\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.985203549245344*^9, 3.9852035739884644`*^9}},
 CellTags->"DefaultContent",
 CellID->386206736,ExpressionUUID->"cea78a15-a9df-4952-981d-cbb49ef59eeb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"model", "=", 
   RowBox[{"CreatePhysicsModel", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PhysicsBoundaryBox", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
         RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
       RowBox[{"FixedBody", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"HatchShading", "[", 
            RowBox[{".6", ",", "Gray"}], "]"}], ",", 
           RowBox[{"Cuboid", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "4"}], ",", 
               RowBox[{"-", "4"}], ",", 
               RowBox[{"-", "1"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"\"\<Restitution\>\"", "->", "1.0"}]}], "]"}], ",", 
       RowBox[{"DynamicBody", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"MaterialShading", "[", "\"\<Gold\>\"", "]"}], ",", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "2.5"}], ",", "0", ",", "5.0"}], "}"}], ",", 
             "0.5"}], "]"}]}], "}"}], ",", 
         RowBox[{"\"\<Restitution\>\"", "->", "0.95"}]}], "]"}], ",", 
       RowBox[{"DynamicBody", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"MaterialShading", "[", "\"\<Copper\>\"", "]"}], ",", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "0.8"}], ",", "0", ",", "5.0"}], "}"}], ",", 
             "0.5"}], "]"}]}], "}"}], ",", 
         RowBox[{"\"\<Restitution\>\"", "->", "0.6"}]}], "]"}], ",", 
       RowBox[{"DynamicBody", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"MaterialShading", "[", "\"\<Silver\>\"", "]"}], ",", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0.8", ",", "0", ",", "5.0"}], "}"}], ",", "0.5"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"\"\<Restitution\>\"", "->", "0.2"}]}], "]"}], ",", 
       RowBox[{"DynamicBody", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"MaterialShading", "[", "\"\<Brass\>\"", "]"}], ",", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"2.5", ",", "0", ",", "5.0"}], "}"}], ",", "0.5"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"\"\<Restitution\>\"", "->", "0.0"}]}], "]"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["2", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["720", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      "Gravity" -> {0, 0, -9.81}, 
       "Graphics3DOptions" -> {
        Background -> Black, Axes -> False, Boxed -> False, ViewPoint -> 
         Front, ImageSize -> Large}],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985203522363866*^9, 3.985203529027529*^9}, {
  3.985203580793983*^9, 3.985203633726818*^9}},
 CellTags->"DefaultContent",
 CellLabel->"In[7]:=",
 CellID->950561860,ExpressionUUID->"7a6041a6-36ea-46c1-b474-0f3a011676e2"],

Cell["Evolve the model for 300 steps with time step 1/60:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9850084989470053`*^9, 3.9850085252486277`*^9}},
 CellID->181949719,ExpressionUUID->"cef1f072-eeca-4d13-8198-783f49ea7c72"],

Cell[BoxData[
 RowBox[{
  RowBox[{"frames", "=", 
   RowBox[{"PhysicsModelEvolve", "[", 
    RowBox[{"model", ",", "300", ",", 
     RowBox[{"1.0", "/", "60.0"}]}], "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985203522363866*^9, 3.985203529907825*^9}},
 CellTags->"DefaultContent",
 CellLabel->"In[8]:=",
 CellID->87374230,ExpressionUUID->"2516b1bb-fdc2-454d-9ac3-fdaba2013e75"],

