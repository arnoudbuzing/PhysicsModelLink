Cell["Create a model with an avalanche of spheres:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.985204018415174*^9, 3.985204060034947*^9}},
 CellTags->"DefaultContent",
 CellID->587481656,ExpressionUUID->"16ea852a-01dc-4f14-b080-5956ccf97138"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "10"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "16"}], "}"}]}], "}"}], "]"}], ",", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", 
            RowBox[{"-", "6"}]}], "}"}], ",", "4"}], "]"}], "}"}], "]"}], ",", 
      RowBox[{"Flatten", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"DynamicBody", "[", 
          RowBox[{"{", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i", ",", "j", ",", "k"}], "}"}], "+", 
              RowBox[{"RandomReal", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "0.01"}], ",", "0.01"}], "}"}], ",", "3"}], 
               "]"}]}], ",", "0.25"}], "]"}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", "14"}], "}"}]}], "]"}]}]}], "}"}], ",", 
    
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", 
        RowBox[{
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], 
          "\[Rule]", 
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]]}], 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Rule", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["928", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     "Graphics3DOptions" -> {
      PlotRange -> 1.05 {{-7, 7}, {-7, 7}, {-10, 10}}, Background -> Black, 
       Axes -> False, Boxed -> False, ViewPoint -> Front, ImageSize -> Large},
     
     SelectWithContents->True,
     Selectable->False]}], "]"}]}]], "Input",
 TaggingRules->{},
