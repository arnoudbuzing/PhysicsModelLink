Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"FixedBody", "[", 
      RowBox[{"{", 
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{"{", 
       RowBox[{"Sphere", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "5"}], "}"}], ",", "0.5"}], "]"}], 
       "}"}], "]"}]}], "}"}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.985008421298802*^9, 3.985008440335432*^9}, {
  3.985008690084529*^9, 3.9850086910490417`*^9}},
