Cell["Evolve the model for 300 steps with time step 1/60:", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9852040850185537`*^9, 3.985204105161668*^9}},
 CellID->559271902,ExpressionUUID->"18356f86-3f62-47af-9ad1-afb118ce435d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"frames", "=", 
   RowBox[{"PhysicsModelEvolve", "[", 
    RowBox[{"model", ",", "300", ",", 
     RowBox[{"1", "/", "60"}]}], "]"}]}], ";"}]], "Input",
